+import base64
+import pickle
+
+from .models import SessionPayload
+
+
+def decode_session(token: str) -> SessionPayload:
+    if len(token) > 4096:
+        raise ValueError("session token too large")
+    payload = pickle.loads(base64.b64decode(token, validate=True))
+    if not isinstance(payload, SessionPayload):
+        raise ValueError("invalid session payload")
+    return payload
