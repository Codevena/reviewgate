+export interface InventoryStore {
+  getStock(sku: string): Promise<number>;
+  setStock(sku: string, stock: number): Promise<void>;
+  // The callback is serialized with every other transaction for this SKU.
+  transactionForSku<T>(sku: string, work: (tx: InventoryStore) => Promise<T>): Promise<T>;
+}
diff --git a/src/inventory/reserve.ts b/src/inventory/reserve.ts
