@@ -0,0 +1,11 @@
+import type { InventoryStore } from "./store.ts";
+
+export function reserve(store: InventoryStore, sku: string, quantity: number) {
+  if (!Number.isSafeInteger(quantity) || quantity <= 0) throw new RangeError("invalid quantity");
+  return store.transactionForSku(sku, async (tx) => {
+    const stock = await tx.getStock(sku);
+    if (stock < quantity) return false;
+    await tx.setStock(sku, stock - quantity);
+    return true;
+  });
+}
