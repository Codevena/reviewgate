@@ -0,0 +1,9 @@
+import type { ProfileDatabase } from "./database.ts";
+
+export async function updateProfile(
+  db: ProfileDatabase,
+  input: { userId: string; displayName: string; locale: string },
+) {
+  await db.updateUser(input.userId, input.displayName);
+  await db.updateSettings(input.userId, input.locale);
+}
