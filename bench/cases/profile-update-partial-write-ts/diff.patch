+export interface ProfileDatabase {
+  updateUser(userId: string, displayName: string): Promise<void>;
+  updateSettings(userId: string, locale: string): Promise<void>;
+  // Rolls back every write made by work when the callback rejects.
+  transaction<T>(work: (tx: ProfileDatabase) => Promise<T>): Promise<T>;
+}
