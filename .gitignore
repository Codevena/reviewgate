# Bun
node_modules
.DS_Store
*.log

# Build
dist
*.tsbuildinfo

# Reviewgate runtime artifacts (we are reviewgate but still want these gitignored in our own repo)
.reviewgate/audit/
.reviewgate/cassettes/
!.reviewgate/cassettes/golden/
.reviewgate/reports/
.reviewgate/pending.*
.reviewgate/plan-review.*
.reviewgate/decisions/
.reviewgate/state.json
.reviewgate/research.md
.reviewgate/dirty.flag
.reviewgate/ESCALATION.md
.reviewgate/.lock
.reviewgate/cache/

# Claude Code local runtime state (session/pid locks, scheduler) — never commit
.claude/scheduled_tasks.lock
.claude/*.lock
# Reviewgate's OWN hook installation here is kept LOCAL (not committed) — so the
# untracked .claude/settings.json must not enter the reviewed diff as a "new file"
# and re-trigger the self-machinery "repo-local hooks = RCE" wolf-cry every cycle.
.claude/settings.json
.claude/settings.local.json

# Spike artifacts
/tmp/reviewgate-spike-*

# Review pipeline scratch (Codex/Claude reviewer outputs — never commit)
.review/

# Editor / local tooling
.vscode/
.idea/

# Local secrets (never commit)
.env
# Reviewgate (auto-added; edit reviewgate.config.ts to override)
.reviewgate/brain/proposals/
.reviewgate/brain/snapshots/
# Antigravity CLI (agy) working-tree artifact
.antigravitycli

# Machine-local cache (absolute paths + UUIDs; not portable project state) — never commit
cache/
